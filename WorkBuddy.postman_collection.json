              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"employeeName\": \"John Doe\",\n  \"month\": \"March\",\n  \"year\": 2026,\n  \"basicSalary\": 85000,\n  \"bonus\": 5000,\n  \"deductions\": 8500\n}"
            }
          }
        },
        {
          "name": "Mark Payroll as Paid",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/payroll/{{payroll_id}}/pay"
          }
