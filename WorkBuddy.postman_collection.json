        {
          "name": "Update Payroll Record",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/payroll/{{payroll_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"employeeName\": \"John Doe\",\n  \"month\": \"March\",\n  \"year\": 2026,\n  \"basicSalary\": 85000,\n  \"bonus\": 7000,\n  \"deductions\": 8500,\n  \"status\": \"Pending\"\n}"
            }
          }
        },
        {
          "name": "Delete Payroll Record",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/payroll/{{payroll_id}}"
          }
        }
      ]
    },
