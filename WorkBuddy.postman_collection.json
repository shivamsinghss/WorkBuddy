{
  "info": {
    "name": "WorkBuddy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "employee_id", "value": "" },
    { "key": "leave_id", "value": "" },
    { "key": "payroll_id", "value": "" },
    { "key": "performance_id", "value": "" },
    { "key": "training_id", "value": "" },
    { "key": "recruitment_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (Employee by Email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john.doe@company.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Employee by Username)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Invalid Credentials)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"wrong\",\n  \"password\": \"wrong\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/employees"
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/employees/{{employee_id}}"
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@company.com\",\n  \"phone\": \"+1 234 567 8900\",\n  \"department\": \"Engineering\",\n  \"position\": \"Software Engineer\",\n  \"joinDate\": \"2024-01-15\",\n  \"salary\": 85000,\n  \"status\": \"Active\",\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/employees/{{employee_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@company.com\",\n  \"phone\": \"+1 234 567 8900\",\n  \"department\": \"Engineering\",\n  \"position\": \"Senior Software Engineer\",\n  \"joinDate\": \"2024-01-15\",\n  \"salary\": 95000,\n  \"status\": \"Active\",\n  \"username\": \"johndoe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/employees/{{employee_id}}"
          }
        }
      ]
    },
    {
      "name": "Leave & Attendance",
      "item": [
        {
          "name": "Get All Leave Requests",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/leaves"
          }
        },
        {
          "name": "Get Leave by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/leaves/{{leave_id}}"
          }
        },
        {
          "name": "Submit Leave Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/leaves",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"employeeName\": \"John Doe\",\n  \"type\": \"Sick Leave\",\n  \"startDate\": \"2026-03-15\",\n  \"endDate\": \"2026-03-17\",\n  \"days\": 3,\n  \"reason\": \"Medical appointment\"\n}"
            }
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/leaves/{{leave_id}}/approve"
          }
        },
        {
          "name": "Reject Leave",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/leaves/{{leave_id}}/reject"
          }
        },
        {
          "name": "Update Leave",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/leaves/{{leave_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"employeeName\": \"John Doe\",\n  \"type\": \"Annual Leave\",\n  \"startDate\": \"2026-03-20\",\n  \"endDate\": \"2026-03-22\",\n  \"days\": 3,\n  \"reason\": \"Vacation\",\n  \"status\": \"Pending\"\n}"
            }
          }
        },
        {
          "name": "Delete Leave",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/leaves/{{leave_id}}"
          }
        }
      ]
    },
    {
      "name": "Payroll",
      "item": [
        {
          "name": "Get All Payroll Records",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/payroll"
          }
        },
        {
